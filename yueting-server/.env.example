# Yueting 项目环境变量配置示例
# 复制此文件为 .env 并填写实际值，或在部署时通过系统环境变量注入

# ============ 数据库 ============
DB_PASSWORD=your_database_password 

# ============ Redis ============
REDIS_PASSWORD=your_redis_password

# ============ 邮件服务 ============
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_email授权码

# ============ JWT ============
JWT_SECRET=your_256bit_random_secret_key

# ============ 阿里云 OSS ============
OSS_ACCESS_KEY_ID=your_aliyun_access_key_id
OSS_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
OSS_BUCKET_NAME=jc-yueting
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_URL=https://jc-yueting.oss-cn-beijing.aliyuncs.com/

# ============ 本地存储路径 ============
IMAGE_STORAGE_TYPE=local
IMAGE_LOCAL_PATH=D:\Data\Work\ProjectUploads\yueting
SONG_LOCAL_PATH=D:\Data\Work\ProjectUploads\yueting

# ============ AI 服务 ============
DASHSCOPE_API_KEY=your_dashscope_api_key
